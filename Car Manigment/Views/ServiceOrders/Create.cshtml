@model Car_Manigment.ViewModels.ServiceOrders.ServiceOrderCreateViewModel
@using Microsoft.AspNetCore.Mvc.Rendering

@{
    ViewData["Title"] = "Create Service Order";
}

<h2>Create Service Order</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label asp-for="Description"></label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="EstimatedPrice"></label>
        <input asp-for="EstimatedPrice" class="form-control" />
        <span asp-validation-for="EstimatedPrice" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="CarId"></label>
        <select asp-for="CarId" asp-items="(SelectList)ViewBag.Cars" class="form-control"></select>
        <span asp-validation-for="CarId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
