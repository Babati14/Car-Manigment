@model Car_Manigment.Models.ServiceOrder

@{
    ViewData["Title"] = "Delete Service Order";
}

<h2>Delete Service Order</h2>

<h4>Are you sure?</h4>
<dl class="row">
    <dt class="col-sm-2">Description</dt><dd class="col-sm-10">@Model.Description</dd>
    <dt class="col-sm-2">Price</dt><dd class="col-sm-10">@Model.EstimatedPrice.ToString("C")</dd>
    <dt class="col-sm-2">Car</dt><dd class="col-sm-10">@Model.Car?.Brand @Model.Car?.Model</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
