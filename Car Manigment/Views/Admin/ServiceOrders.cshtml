@model IEnumerable<Car_Manigment.ViewModels.Admin.AdminServiceOrderViewModel>
@{
    ViewData["Title"] = "Manage Service Orders";
}

<h1>All Service Orders</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Description</th>
            <th>Price</th>
            <th>Status</th>
            <th>Car</th>
            <th>Created By</th>
            <th>Created On</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var order in Model)
        {
            <tr>
                <td>@order.Description</td>
                <td>@order.EstimatedPrice.ToString("C")</td>
                <td>@order.Status</td>
                <td>@order.CarDisplayName</td>
                <td>@(order.CreatedByEmail ?? "N/A")</td>
                <td>@order.CreatedOn.ToString("g")</td>
                <td>
                    <a asp-action="EditServiceOrder" asp-route-id="@order.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="DeleteServiceOrder" asp-route-id="@order.Id" method="post" style="display:inline;">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this service order?');">Delete</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Index" class="btn btn-secondary">Back to Dashboard</a>
