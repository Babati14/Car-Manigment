@model Car_Manigment.ViewModels.Cars.CarDetailsViewModel

@{
    ViewData["Title"] = "Car Details";
}

<h2>Car Details</h2>

<dl class="row">
    <dt class="col-sm-2">Brand</dt><dd class="col-sm-10">@Model.Brand</dd>
    <dt class="col-sm-2">Model</dt><dd class="col-sm-10">@Model.Model</dd>
    <dt class="col-sm-2">Year</dt><dd class="col-sm-10">@Model.Year</dd>
    <dt class="col-sm-2">VIN</dt><dd class="col-sm-10">@Model.VinNumber</dd>
    <dt class="col-sm-2">Owner</dt><dd class="col-sm-10">@Model.OwnerName</dd>
    <dt class="col-sm-2">Phone</dt><dd class="col-sm-10">@Model.OwnerPhone</dd>
</dl>

<h3>Service Orders</h3>
@if (Model.ServiceOrders != null && Model.ServiceOrders.Any())
{
    <table class="table">
        <thead><tr><th>Description</th><th>Price</th><th>Status</th><th>Created</th></tr></thead>
        <tbody>
        @foreach (var so in Model.ServiceOrders)
        {
            <tr>
                <td>@so.Description</td>
                <td>@so.EstimatedPrice.ToString("C")</td>
                <td>@so.Status</td>
                <td>@so.CreatedOn.ToString("g")</td>
            </tr>
        }
        </tbody>
    </table>
}
else
{
    <p>No service orders.</p>
}
