@model IEnumerable<Car_Manigment.ViewModels.Cars.CarListViewModel>

@{
    ViewData["Title"] = "Cars";
    var count = (Model ?? Enumerable.Empty<Car_Manigment.ViewModels.Cars.CarListViewModel>()).Count();
}

<h2>Cars (@count)</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<p>
    <a asp-action="Create" asp-controller="Cars" class="btn btn-primary">Create New Car</a>
</p>

<div class="card mb-3">
    <div class="card-header">
        <strong>Search & Filter</strong>
    </div>
    <div class="card-body">
        <form method="get" asp-action="Index">
            <div class="row">
                <div class="col-md-4">
                    <label for="searchBrand" class="form-label">Brand</label>
                    <input type="text" id="searchBrand" name="searchBrand" class="form-control" placeholder="e.g. Toyota" value="@ViewBag.SearchBrand" />
                </div>
                <div class="col-md-4">
                    <label for="searchModel" class="form-label">Model</label>
                    <input type="text" id="searchModel" name="searchModel" class="form-control" placeholder="e.g. Camry" value="@ViewBag.SearchModel" />
                </div>
                <div class="col-md-2">
                    <label for="searchYear" class="form-label">Year</label>
                    <input type="number" id="searchYear" name="searchYear" class="form-control" placeholder="e.g. 2020" value="@ViewBag.SearchYear" min="1980" max="2100" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary me-2">Search</button>
                    <a asp-action="Index" class="btn btn-secondary">Clear</a>
                </div>
            </div>
        </form>
    </div>
</div>


@if (!Model.Any())
{
    <div class="alert alert-info">No cars found. Add one using the "Create New Car" button.</div>
}
else
{
    <table class="table table-striped">
        <thead><tr><th>Brand</th><th>Model</th><th>Year</th><th></th></tr></thead>
        <tbody>
            @foreach (var car in Model)
            {
                <tr>
                    <td>@car.Brand</td>
                    <td>@car.Model</td>
                    <td>@car.Year</td>
                    <td>
                        <a asp-action="Details" asp-controller="Cars" asp-route-id="@car.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}