@model IEnumerable<Car_Manigment.ViewModels.Cars.CarListViewModel>

@{
    ViewData["Title"] = "Cars";
}

<h2>Cars</h2>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New Car</a>
</p>

<table class="table table-striped">
    <thead><tr><th>Brand</th><th>Model</th><th>Year</th><th></th></tr></thead>
    <tbody>
    @foreach (var car in Model)
    {
        <tr>
            <td>@car.Brand</td>
            <td>@car.Model</td>
            <td>@car.Year</td>
            <td>
                <a asp-action="Details" asp-route-id="@car.Id">Details</a>
            </td>
        </tr>
    }
    </tbody>
</table>
